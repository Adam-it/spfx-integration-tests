{
  "tests": [
    {
      "name": "Webpart renders correctly",
      "steps": [
        { "action": "waitForSelector", "selector": "div[data-sp-feature-tag*='HelloWorldWebPart']", "timeout": 30000 },
        { "action": "assertVisible", "selector": "div[data-sp-feature-tag*='HelloWorldWebPart']" },
        { "action": "assertTextContains", "selector": "div[data-sp-feature-tag*='HelloWorldWebPart']", "text": "Welcome to SharePoint" },
        { "action": "screenshot", "name": "webpart-rendered" }
      ]
    },
    {
      "name": "Property pane interaction",
      "steps": [
        { "action": "enterEditMode", "timeout": 30000 },
        { "action": "waitForSelector", "selector": "div[data-sp-feature-tag*='HelloWorldWebPart']", "timeout": 30000 },
        { "action": "openPropertyPane", "selector": "div[data-sp-feature-tag*='HelloWorldWebPart']", "timeout": 30000 },
        { "action": "screenshot", "name": "property-pane-open" }
      ]
    }
  ]
}
